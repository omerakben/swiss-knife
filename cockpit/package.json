{
  "name": "haven-desk-cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "db:push": "prisma db push",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "clean": "node -e \"fs.rmSync('.next',{recursive:true,force:true})\"",
    "postinstall": "prisma generate",
    "db:seed": "node --env-file-if-exists=.env prisma/seed.mjs",
    "seed:lbmh": "node --env-file-if-exists=.env prisma/seed-lbmh.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-slider": "1.4.0",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tabs": "1.1.14",
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "22.19.21",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.47",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
