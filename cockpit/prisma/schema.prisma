generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Phase 1: prompt optimizer + library
model Prompt {
  id        String   @id @default(cuid())
  title     String
  original  String
  optimized String?
  tags      String?
  createdAt DateTime @default(now())

  // Optional project link (light grouping now; full hub later).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// Lightweight grouping used across tools; grows in later phases.
model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  prompts Prompt[]
}

// Single-row app settings (single-user). Enforced via fixed id + upsert.
// Null fields fall back to env/defaults in lib/config.ts.
model Settings {
  id          String   @id @default("singleton")
  model       String?
  temperature Float?
  baseUrl     String?
  theme       String?  @default("system")
  updatedAt   DateTime @updatedAt
}
